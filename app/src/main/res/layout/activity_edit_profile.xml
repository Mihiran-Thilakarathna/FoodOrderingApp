<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main_edit_profile_layout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8F9FA">

    <TextView
        android:id="@+id/tvEditProfileTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Edit Profile"
        android:textAlignment="center"
        android:textSize="22sp"
        android:textStyle="bold"
        android:textColor="@color/black"
        android:padding="20dp"
        app:layout_constraintTop_toTopOf="parent" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintTop_toBottomOf="@id/tvEditProfileTitle"
        app:layout_constraintBottom_toBottomOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:padding="20dp">

            <FrameLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp">

                <ImageView
                    android:id="@+id/imgEditProfile"
                    android:layout_width="120dp"
                    android:layout_height="120dp"
                    android:background="@drawable/bg_circle"
                    android:clipToOutline="true"
                    android:scaleType="centerCrop"
                    android:src="@drawable/ic_dummy_profile" />

                <TextView
                    android:layout_width="35dp"
                    android:layout_height="35dp"
                    android:layout_gravity="bottom|end"
                    android:background="@drawable/bg_circle"
                    android:backgroundTint="#FFC107"
                    android:gravity="center"
                    android:text="📷"
                    android:textColor="@color/black"
                    android:textSize="16sp" />
            </FrameLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="Tap picture to change"
                android:textColor="#757575"
                android:textSize="14sp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginTop="30dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Email Address"
                    android:textColor="#757575"
                    android:textSize="14sp"
                    android:layout_marginBottom="5dp"/>

                <EditText
                    android:id="@+id/etEditEmail"
                    android:layout_width="match_parent"
                    android:layout_height="55dp"
                    android:background="@drawable/bg_rounded_edittext"
                    android:paddingHorizontal="20dp"
                    android:inputType="textEmailAddress"
                    android:textColor="@color/black"
                    android:hint="Enter email address"
                    android:textColorHint="#9E9E9E"
                    android:autofillHints="emailAddress"
                    android:layout_marginBottom="20dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Phone Number"
                    android:textColor="#757575"
                    android:textSize="14sp"
                    android:layout_marginBottom="5dp"/>

                <EditText
                    android:id="@+id/etEditPhone"
                    android:layout_width="match_parent"
                    android:layout_height="55dp"
                    android:background="@drawable/bg_rounded_edittext"
                    android:paddingHorizontal="20dp"
                    android:inputType="phone"
                    android:textColor="@color/black"
                    android:hint="Enter phone number"
                    android:textColorHint="#9E9E9E"
                    android:autofillHints="phone"
                    android:layout_marginBottom="20dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Delivery Address"
                    android:textColor="#757575"
                    android:textSize="14sp"
                    android:layout_marginBottom="5dp"/>

                <EditText
                    android:id="@+id/etEditAddress"
                    android:layout_width="match_parent"
                    android:layout_height="100dp"
                    android:background="@drawable/bg_rounded_edittext"
                    android:paddingHorizontal="20dp"
                    android:paddingVertical="15dp"
                    android:inputType="textMultiLine"
                    android:gravity="top|start"
                    android:textColor="@color/black"
                    android:hint="Enter your full delivery address"
                    android:textColorHint="#9E9E9E"
                    android:autofillHints="postalAddress"
                    android:layout_marginBottom="30dp"/>

                <Button
                    android:id="@+id/btnSaveProfile"
                    android:layout_width="match_parent"
                    android:layout_height="60dp"
                    android:backgroundTint="#FF5722"
                    android:text="Save Changes"
                    android:textColor="@color/white"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    app:cornerRadius="15dp" />

            </LinearLayout>
        </LinearLayout>
    </ScrollView>
</androidx.constraintlayout.widget.ConstraintLayout>